<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".identityverification.IdentityVerificationConsentFragment">

    <include
        android:id="@+id/toolbar"
        layout="@layout/layout_toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Consent Requirement Status Section -->
            <TextView
                android:id="@+id/consentRequirementLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/consent_requirement_status"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary" />

            <TextView
                android:id="@+id/consentRequirementText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="@string/checking_consent_requirement"
                android:textSize="14sp"
                android:padding="12dp"
                android:background="#FFFFFF"
                android:textColor="@android:color/black" />

            <!-- Current Consent Status Section -->
            <TextView
                android:id="@+id/consentStatusLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/consent_status"
                android:textColor="@color/colorPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/consentStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="@string/consent_status_placeholder"
                android:textSize="14sp"
                android:padding="12dp"
                android:background="#FFFFFF"
                android:textColor="@android:color/black" />


            <!-- Consent Text Retrieval Section -->
            <TextView
                android:id="@+id/consentTextLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/consent_text_label"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary" />

            <Button
                android:id="@+id/retrieveConsentTextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/retrieve_consent_text"
                android:background="@color/colorPrimary"
                android:textColor="#FFFFFF"
                android:padding="16dp" />

            <ScrollView
                android:id="@+id/consentTextScrollView"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="24dp"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/consentTextContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="@android:color/black"
                    android:lineSpacingMultiplier="1.2" />

            </ScrollView>

            <Button
                android:id="@+id/provideConsentButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/provide_consent"
                android:background="@color/colorPrimary"
                android:textColor="#FFFFFF"
                android:padding="16dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/withdrawConsentButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="@string/withdraw_consent"
                android:background="#FF6B6B"
                android:textColor="#FFFFFF"
                android:padding="16dp"
                android:visibility="gone" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
